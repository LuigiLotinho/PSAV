# ===========================================
# Vercel Environment Variables – siehe VERCEL_SETUP.md
# ===========================================

# Datenbank (Prisma) – PostgreSQL von Neon, Supabase, Railway etc.
DATABASE_URL="postgresql://USER:PASSWORT@HOST:PORT/DATENBANK?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORT@HOST:PORT/DATENBANK?sslmode=require"

# NextAuth – PFLICHT in Produktion (Vercel)
AUTH_SECRET="<erzeuge-mit-npx-auth-secret-oder-openssl-rand-base64-32>"
AUTH_URL="https://dein-projekt.vercel.app"

# OpenAI – für Übersetzung von User-Inhalten (Probleme/Lösungen) in alle 10 Sprachen
# Ohne Key werden Inhalte nicht übersetzt (Fallback auf Original)
OPENAI_API_KEY="sk-..."
